# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Application ──────────────────────────────────
APP_NAME=PropoAI
DEBUG=false

# ── Security ─────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=1440   # 24 hours
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── PostgreSQL ───────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=propoai
POSTGRES_PASSWORD=propoai_pass
POSTGRES_DB=propoai

# ── CORS ─────────────────────────────────────────
# Comma-separated list of allowed origins (JSON array format)
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── First super-admin (seeded on first start) ────
FIRST_SUPERUSER_EMAIL=admin@propoai.com
FIRST_SUPERUSER_PASSWORD=Admin@123456
FIRST_SUPERUSER_NAME=Admin
